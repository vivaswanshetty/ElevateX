# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/elevatex

# JWT Secret — MUST be a strong random value in production (min 32 chars)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Payment Configuration (Razorpay)
# Use TEST keys for development, LIVE keys only in production env vars
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_key_secret_here

# Email Configuration
EMAIL_SERVICE=Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
SUPPORT_EMAIL=support@elevatex.com
